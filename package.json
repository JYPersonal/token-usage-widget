{
  "name": "token-usage-dashboard",
  "version": "1.0.0",
  "description": "Local Windows corner widget + dashboard for Codex, Cursor, and other AI harness quotas. MIT, localhost-only.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JYPersonal/token-usage-widget.git"
  },
  "bugs": {
    "url": "https://github.com/JYPersonal/token-usage-widget/issues"
  },
  "homepage": "https://github.com/JYPersonal/token-usage-widget#readme",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "setup": "tsx src/cli/setup.ts",
    "setup:defaults": "tsx src/cli/setup.ts --defaults",
    "setup:all": "tsx src/cli/setup.ts --defaults --all",
    "widget": "electron .",
    "widget:bg": "scripts\\start-widget.cmd",
    "widget:startup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-widget.ps1 -InstallStartup",
    "test": "node --import tsx --test tests/usage.test.ts tests/providers.test.ts tests/e2e-smoke.test.ts tests/server-launch.test.cjs tests/format-reset.test.cjs tests/widget-compact.test.cjs",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && node scripts/e2e-evidence.mjs"
  },
  "keywords": [
    "tokens",
    "usage",
    "dashboard",
    "widget",
    "codex",
    "opencode",
    "cursor",
    "claude",
    "openrouter",
    "kimi",
    "zai",
    "grok"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "codex-status-mcp": "^0.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "electron": "^35.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
